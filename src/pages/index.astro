              ) : (
                <>
                  {/* Unified banner for playing and not-playing; show small playing indicator when live */}
                  <div class={`np-banner ${nowPlaying.isNowPlaying ? 'playing' : ''}`}>
                    <img src={nowPlaying.cover} alt="cover" />
                    <a id="lastfm-badge" class="lastfm-icon" href={`https://last.fm/user/${import.meta.env.LASTFM_USERNAME || 'Lmpamapa'}`} target="_blank" rel="noreferrer" aria-label="Last.fm" data-tooltip="powered by Last.fm">
                      <svg viewBox="0 0 32 32" width="18" height="18" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M14.131 22.948l-1.172-3.193c0 0-1.912 2.131-4.771 2.131-2.537 0-4.333-2.203-4.333-5.729 0-4.511 2.276-6.125 4.515-6.125 3.224 0 4.245 2.089 5.125 4.772l1.161 3.667c1.161 3.561 3.365 6.421 9.713 6.421 4.548 0 7.631-1.391 7.631-5.068 0-2.968-1.697-4.511-4.844-5.244l-2.344-0.511c-1.624-0.371-2.104-1.032-2.104-2.131 0-1.249.985-1.984 2.604-1.984 1.767 0 2.704 0.661 2.865 2.24l3.661-0.444c-0.297-3.301-2.584-4.656-6.323-4.656-3.308 0-6.532 1.251-6.532 5.245 0 2.5 1.204 4.077 4.245 4.807l2.484 0.589c1.865 0.443 2.484 1.224 2.484 2.287 0 1.359-1.323 1.921-3.828 1.921-3.703 0-5.244-1.943-6.124-4.625l-1.204-3.667c-1.541-4.765-4.005-6.531-8.891-6.531-5.287-.016-8.151 3.385-8.151 9.192 0 5.573 2.864 8.595 8.005 8.595 4.14 0 6.125-1.943 6.125-1.943z"/></svg>
                    </a>
                    <m3e-tooltip for="lastfm-badge">powered by Last.fm</m3e-tooltip>
                    {/* top-left: user pfp + name + time */}
                    <a id="lastfm-user" class="np-user-top-left" href={`https://last.fm/user/${import.meta.env.LASTFM_USERNAME || 'Lmpamapa'}`} target="_blank" rel="noreferrer" aria-label={`Last.fm user ${import.meta.env.LASTFM_USERNAME || 'Lmpamapa'}`} data-tooltip={import.meta.env.LASTFM_USERNAME || 'Lmpamapa'}>
                      <img class="np-user-pfp" src={nowPlaying?.userAvatar ?? 'https://lastfm.freetls.fastly.net/i/u/avatar170s/7c5e1dd9c4c40b2fe18332311caea308.png'} alt="avatar" />
                      <span class="np-user-name">{import.meta.env.LASTFM_USERNAME || 'Lmpamapa'}{nowPlaying && nowPlaying.from && !nowPlaying.isNowPlaying ? ` • ${Math.round((Date.now() - nowPlaying.from) / 3600000)}h ago` : nowPlaying && nowPlaying.isNowPlaying ? ' • now' : ''}</span>
                    </a>

                    {nowPlaying.isNowPlaying ? (
                      <span class="playing-indicator top-left" aria-hidden="true"><span></span><span></span><span></span></span>
                    ) : nowPlaying.from ? (
                      <span class="time-ago top-left">{Math.round((Date.now() - nowPlaying.from) / 3600000)}h ago</span>
                    ) : null}
                    <m3e-tooltip for="lastfm-user">{`Last.fm: ${import.meta.env.LASTFM_USERNAME || 'Lmpamapa'}`}</m3e-tooltip>
                    <div class="np-banner-overlay">
                      <a class="np-artist np-artist-link" href={nowPlaying.link ? nowPlaying.link : `https://music.youtube.com/search?q=${encodeURIComponent(nowPlaying.artistName + ' ' + nowPlaying.songName)}`} target="_blank" rel="noreferrer">{nowPlaying.artistName}</a>
                      <a class="np-title-link" href={nowPlaying.link ? nowPlaying.link : `https://music.youtube.com/search?q=${encodeURIComponent(nowPlaying.artistName + ' ' + nowPlaying.songName)}`} target="_blank" rel="noreferrer">
                        <div class="np-title">{nowPlaying.songName}</div>
                      </a>
                      {nowPlaying.albumName ? <div class="muted-2">{nowPlaying.albumName}</div> : null}
                    </div>
                  </div>
                </>
              )}
            </div>
          </div>

          {posts.length > 0 ? (
            <div class="card">
                  <span class="card-icon card-icon--alt">
                      <m3e-shape name="6-sided-cookie" class="card-shape" style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);--m3e-shape-size:40px;display:block"></m3e-shape>
                      <span class="card-icon-inner"><span class="material-symbols-outlined">article</span></span>
                  </span>
              <h2 class="card-title">recent posts</h2>
              <div class="link-list">
                {posts.map((post) => (
                  <a class="link-row" href={`/blog/${post.slug}`}>
                    <div>
                      <b>{post.data.title}</b>
                      <span class="muted-2">{post.data.description}</span>
                    </div>
                    <span class="muted-2 link-date">{post.data.date.toLocaleDateString('en-GB')}</span>
                  </a>
                ))}
              </div>
              <a class="card-footer-link" href="/blog">all posts <span class="material-symbols-outlined" style="font-size:16px">chevron_forward</span></a>
            </div>
          ) : null}

          <div class="card">
            <span class="card-icon card-icon--alt">
              <m3e-shape name="pixel-circle" class="card-shape" style="--m3e-shape-container-color:var(--md-sys-color-secondary-container);--m3e-shape-size:40px;display:block"></m3e-shape>
              <span class="card-icon-inner"><span class="material-symbols-outlined">grid_view</span></span>
            </span>
            <h2 class="card-title">88x31</h2>
            <div class="badge-grid">
              <a class="badge-link" href="/images/88x31.svg" target="_blank" rel="noreferrer">
                <img src="/images/88x31.svg" alt="lamp.delivery" class="badge-img" />
              </a>
              <a class="badge-link" href="https://elissa.moe" target="_blank" rel="noreferrer">
                <img src="https://elissa.moe/88x31.png" alt="elissa.moe" class="badge-img" />
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="footer-wrap">
        <footer class="card site-footer">
          <div class="footer-icon-row">
            <a id="ficon-github" class="ficon" href="https://github.com/l6t9" target="_blank" aria-label="GitHub" data-tooltip="GitHub">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.73.083-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.776.417-1.306.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
            </a>
            <m3e-tooltip for="ficon-github" position="above">GitHub</m3e-tooltip>
            <a id="ficon-codeberg" class="ficon" href="https://codeberg.org/LampDelivery" target="_blank" aria-label="Codeberg" data-tooltip="Codeberg">
              <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" width="24" height="24"><path d="M12 1A11 11 0 0 0 1 12a11 11 0 0 0 1.7 6.4L12 6l9.3 12.4A11 11 0 0 0 23 12 11 11 0 0 0 12 1Z"/><path d="M21.3 18.4 12 6l4.4 16.8a11 11 0 0 0 4.9-4.4Z"/></svg>
            </a>
            <m3e-tooltip for="ficon-codeberg" position="above">Codeberg</m3e-tooltip>
            <a id="ficon-discord" class="ficon" href="https://discord.com/users/650805815623680030" target="_blank" aria-label="Discord" data-tooltip="Discord">
              <svg viewBox="0 0 127.14 96.36" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"><path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.31 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.52-4.51-51.48-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"/></svg>
            </a>
            <m3e-tooltip for="ficon-discord" position="above">Discord</m3e-tooltip>
            <a id="ficon-youtube" class="ficon" href="https://youtube.com/@LampDelivery" target="_blank" aria-label="YouTube" data-tooltip="YouTube">
              <svg viewBox="0 0 576 512" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"><path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.322 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"/></svg>
            </a>
            <m3e-tooltip for="ficon-youtube" position="above">YouTube</m3e-tooltip>
            <a id="ficon-lastfm" class="ficon" href="https://last.fm/user/Lmpamapa" target="_blank" aria-label="Last.fm" data-tooltip="Last.fm">
              <svg viewBox="0 0 32 32" width="24" height="24" fill="currentColor"><path d="M14.131 22.948l-1.172-3.193c0 0-1.912 2.131-4.771 2.131-2.537 0-4.333-2.203-4.333-5.729 0-4.511 2.276-6.125 4.515-6.125 3.224 0 4.245 2.089 5.125 4.772l1.161 3.667c1.161 3.561 3.365 6.421 9.713 6.421 4.548 0 7.631-1.391 7.631-5.068 0-2.968-1.697-4.511-4.844-5.244l-2.344-0.511c-1.624-0.371-2.104-1.032-2.104-2.131 0-1.249.985-1.984 2.604-1.984 1.767 0 2.704 0.661 2.865 2.24l3.661-0.444c-0.297-3.301-2.584-4.656-6.323-4.656-3.308 0-6.532 1.251-6.532 5.245 0 2.5 1.204 4.077 4.245 4.807l2.484 0.589c1.865 0.443 2.484 1.224 2.484 2.287 0 1.359-1.323 1.921-3.828 1.921-3.703 0-5.244-1.943-6.124-4.625l-1.204-3.667c-1.541-4.765-4.005-6.531-8.891-6.531-5.287-.016-8.151 3.385-8.151 9.192 0 5.573 2.864 8.595 8.005 8.595 4.14 0 6.125-1.943 6.125-1.943z"/></svg>
            </a>
            <m3e-tooltip for="ficon-lastfm" position="above">Last.fm</m3e-tooltip>
