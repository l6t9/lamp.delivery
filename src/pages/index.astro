---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getNowPlaying } from '../lib/nowPlaying';

const posts = (await getCollection('blog', ({ data }) => data.published)).sort(
  (first, second) => second.data.date.getTime() - first.data.date.getTime()
).slice(0, 3);

const nowPlaying = await getNowPlaying();
const localHour = new Date().toLocaleTimeString('en-GB', {
  timeZone: 'Etc/GMT+5',
  hour: '2-digit',
  minute: '2-digit'
});
---

<BaseLayout title="lamp.delivery" description="hai" pathname="/">
  <main class="home">
    <section class="banner">
      <div class="banner-bg">
        <svg class="stars-svg" viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <rect width="1440" height="600" fill="var(--md-sys-color-surface-container-lowest)"/>
        </svg>

        <div class="s-star" style="--x:8%;--y:12%;--m3e-shape-size:8px;--d:3.2s"><m3e-shape name="gem" style="--m3e-shape-container-color:#fff0c0"></m3e-shape></div>
        <div class="s-star" style="--x:22%;--y:6%;--m3e-shape-size:6px;--d:4.7s"><m3e-shape name="6-sided-cookie" style="--m3e-shape-container-color:#fff0c0"></m3e-shape></div>
        <div class="s-star" style="--x:35%;--y:18%;--m3e-shape-size:10px;--d:5.1s"><m3e-shape name="puffy" style="--m3e-shape-container-color:#fff0c0"></m3e-shape></div>
