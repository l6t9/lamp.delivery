---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="other stuff | lamp.delivery" description="Other things LampDelivery has made or keeps around." pathname="/other-stuff">
  <main class="page">
    <div class="card">
      <span class="card-icon card-icon--alt">
        <span class="material-symbols-outlined">more_horiz</span>
      </span>
      <h2 class="card-title">other stuff</h2>
      <p class="muted intro">things I've worked on, plus a few extra links and side quests.</p>

      <div class="link-list">
        <a class="link-row" href="https://metrolist.cc" target="_blank" rel="noreferrer">
          <span class="link-icon link-icon--sm">
            <svg viewBox="0 0 1000 1000" width="18" height="18" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M553.5,135L578,135.5L592.5,139L614,149.5Q631.5,161.5 644.5,178L726,258.5L726.5,260L852,384.5L766.5,471L758.5,462L757,461.5L748.5,452L676,381.5L662.5,367L655,360.5L641.5,346L634,339.5L632.5,337L631,336.5L627.5,332L624,329.5L621.5,326L602.5,308L602,571.5L602,637.5Q599.9,673.9 580.5,693L553.5,721L441.5,833L430,843.5L429.5,845L410,857.5Q399.9,864.4 384.5,866L380,866.5L364.5,867L360.5,866L352.5,865Q333.3,860.3 320,849.5L302,833.5L300.5,831L295,826.5L294.5,825L279,810.5L278.5,809L172,703.5Q163.4,693.6 158,680.5Q154,673.5 153,663.5L151.5,652L151,641.5L154,625.5Q158.5,603.5 172,590.5L200,561.5L296.5,465L300,462.5L315.5,446L320,448.5L326,454.5L337.5,467L346,474.5L358.5,488L367,495.5L379.5,509L388,516.5L390.5,520L395,523.5L398.5,528L403,531.5L387,546.5L384.5,550L381,552.5L378.5,556L309,623.5L287,646.5L350.5,710L366,725.5L370,729.5Q371.3,732.3 372.5,730L377,725.5L394,708.5L461.5,641L467,636.5L467.5,635L475,628.5L475.5,627L478,625.5L480,622.5L481,617.5L481,603.5L481,546.5L481,321.5L481,235.5L481.5,214L484,197.5L487.5,188L493,176.5Q500.2,164.2 510.5,155L530,142.5L544,137.5L553.5,135Z"/></svg>
          </span>
          <div>
            <b>Metrolist</b>
            <span class="muted-2">YouTube Music client for Android</span>
          </div>
          <span class="material-symbols-outlined link-arrow">chevron_forward</span>
        </a>
        <a class="link-row" href="https://github.com/Aliucord/LumiBot" target="_blank" rel="noreferrer">
          <span class="link-icon link-icon--sm">
            <svg viewBox="0 0 512 512" width="18" height="18" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M310.423 321.724C290.671 371.359 209.633 359.204 209.633 316.152V192.57C209.633 147.999 289.658 137.869 313.969 182.44L387.916 152.557C359.046 88.74 305.865 70 261.801 70C189.88 70 118.972 111.532 118.972 192.57V316.152C118.972 397.696 189.88 438.722 260.281 438.722C305.359 438.722 359.553 416.436 389.435 358.191L310.423 321.724Z"/><path fill-rule="evenodd" clip-rule="evenodd" d="M212.667 79.2324H296.257L426.001 442.31H327.539L303.949 369.489H207.026L184.462 442.31H86L139.851 287.951H227.539H281.898L256.77 181.797H254.205L238.559 244.082L176.78 182.098L212.667 79.2324Z"/><path d="M389.433 358.196L310.421 321.729C301.312 349.89 287.34 358.841 255.487 369.493L321.862 424.793C348.112 412.353 372.62 390.966 389.433 358.196Z"/></svg>
          </span>
          <div>
            <b>LumiBot</b>
            <span class="muted-2">Utility bot for Aliucord's Discord server</span>
          </div>
          <span class="material-symbols-outlined link-arrow">chevron_forward</span>
        </a>
      </div>

      <a class="card-footer-link" href="/">back home <span class="material-symbols-outlined" style="font-size:16px">chevron_forward</span></a>
    </div>
  </main>
</BaseLayout>

<script>
  import '@m3e/web/icon';
</script>

<style>
  .page {
    display: flex;
    flex-direction: column;
    gap: var(--home-gap, 24px);
  }

  .intro {
    max-width: 56ch;
  }
</style>
