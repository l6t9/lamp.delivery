  </main>
</BaseLayout>

<script>
  import '@m3e/web/icon';
  import '@m3e/web/shape';
  import '@m3e/web/tooltip';
</script>

<style>
  :root {
    --card-radius: 28px;
    --list-radius: 16px;
    --link-radius: 4px;
    --content-max: min(1200px, calc(100vw - 20px));
    --home-gap: 24px;
  }

  .home {
    width: 100%;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    overflow-x: hidden;
  }

  /* ═══ BANNER — Night Sky ═══ */
  .banner {
    width: 100vw;
    height: calc(100vh - 6em - 40px);
    min-height: 512px;
    max-height: 600px;
    position: relative;
    overflow: visible;
    background: var(--md-sys-color-surface-container-lowest);
  }

  .banner-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--md-sys-color-surface-container-lowest);
  }

  .stars-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .s-star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--m3e-shape-size);
    height: var(--m3e-shape-size);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
    animation: s-spin var(--d, 5s) ease-in-out infinite;
  }

  .s-star--glow {
    filter: drop-shadow(0 0 6px #ffc234);
  }

  .s-star--glow-alt {
    filter: drop-shadow(0 0 4px #ffe082);
  }

  @keyframes s-spin {
    0%, 100% { opacity: 0; transform: rotate(0deg); }
    30% { opacity: 0.7; transform: rotate(360deg); }
    70% { opacity: 0.7; transform: rotate(720deg); }
  }

  .banner-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 6em;
    background: linear-gradient(to bottom, transparent 0%, var(--md-sys-color-surface-container-lowest) 70%);
    pointer-events: none;
    z-index: 10;
  }

  /* ── Mask Ring (Avatar with spinning cookie frame) ── */

  @property --spin {
    syntax: '<number>';
    inherits: true;
    initial-value: 0;
  }

  .mask-ring {
    width: 340px;
    height: 340px;
    z-index: 3;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    animation: spin-driver 105s linear infinite;
  }

  @keyframes spin-driver {
    0% { --spin: 0; }
    100% { --spin: 1; }
  }

  .cookie-shape {
    --m3e-shape-size: 340px;
  }

  .cookie-spin {
    position: absolute;
    inset: 0;
    z-index: 1;
    rotate: calc(var(--spin) * 1080deg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cookie-avatar {
    rotate: calc(var(--spin) * -1080deg);
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ═══ CONTENT AREA ═══ */
  .content-area {
    background: var(--md-sys-color-surface-container-lowest);
    width: 100vw;
    position: relative;
    z-index: 1;
  }

  .content-row {
    display: flex;
    flex-direction: row;
    gap: var(--home-gap);
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 10px 48px;
    position: relative;
    z-index: 1;
  }

  .col-left,
  .col-right {
    display: flex;
    flex-direction: column;
    gap: var(--home-gap);
    width: 100%;
  }

  /* ═══ CARDS ═══ */
  .card {
    background: var(--md-sys-color-surface);
    border-radius: var(--card-radius);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 1em;
    position: relative;
  }

  .card-icon {
    width: 44px;
    height: 44px;
    background: transparent;
    color: var(--md-sys-color-on-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: visible;
    box-sizing: border-box;
    position: relative;
  }

  .card-icon .material-symbols-outlined {
    font-size: 22px;
  }

  .card-icon m3e-shape {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    box-sizing: border-box;
    max-width: 100%;
    max-height: 100%;
    overflow: visible;
    --m3e-shape-size: 40px;
    z-index: 1;
  }
  .card-icon-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .card-icon--alt {
    background: transparent;
    color: var(--md-sys-color-on-secondary-container);
  }

  .card-title {
    font-family: 'Google Sans Flex', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0;
  }

  .card-footer-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.9rem;
    color: var(--md-sys-color-primary);
    text-decoration: none;
    margin-top: 4px;
    width: fit-content;
  }

  /* ── Profile Card ── */
  .card-profile {
    min-height: 280px;
  }

  .profile-body {
    display: flex;
    flex-direction: column;
    gap: 1em;
    max-width: 100%;
  }

  .profile-greeting {
    font-family: 'Google Sans Flex', system-ui, sans-serif;
    font-size: 2.2rem;
    font-weight: 500;
    margin: 0;
  }

  .profile-likes {
    margin: 0;
    padding: 0 0 0 20px;
  }

  .profile-likes li {
    font-size: 0.95rem;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.6;
  }

  .profile-tz {
    font-size: 0.85rem;
  }

  /* ── Link List ── */
  .link-list {
    border-radius: var(--list-radius);
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow: hidden;
  }

  .link-row {
    color: var(--md-sys-color-on-surface);
    background: var(--md-sys-color-surface-container-low);
    border-radius: var(--link-radius);
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 14px;
    padding: 12px;
    text-decoration: none;
    position: relative;
    transition: background 0.2s ease;
  }

  .link-row:hover {
    background: var(--md-sys-color-surface-container-high);
  }

  .link-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--md-sys-color-surface-container-high);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--md-sys-color-primary);
  }

  .link-icon--sm {
    width: 44px;
    height: 44px;
  }

  .link-icon svg {
    width: 20px;
    height: 20px;
  }

  .link-icon--sm img,
  .link-icon img.friend-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .link-row > div {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
    min-width: 0;
  }

  .link-row > div > b {
    font-family: 'Google Sans Flex', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .link-row > div > span {
    font-size: 0.8rem;
  }

  .link-arrow {
    font-size: 1.1rem;
    color: var(--md-sys-color-outline);
    flex-shrink: 0;
  }

  .link-date {
    font-size: 0.8rem;
    white-space: nowrap;
  }

  /* ── Now Playing ── */
  .now-playing {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .np-cover {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid var(--md-sys-color-outline-variant);
  }

  .np-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .np-info b {
    font-family: 'Google Sans Flex', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .np-info span {
    font-size: 0.85rem;
  }

  /* Bignut-inspired now-playing styling */
  .now-playing-card {
    padding-bottom: 12px;
  }

  .np-cover-wrap {
    width: 76px;
    height: 76px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
  }

  .np-banner {
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    min-height: 160px;
  }

  .np-banner img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .np-banner-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    color: white;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.32) 35%, rgba(0,0,0,0.6) 100%);
    padding: 16px 18px;
  }

  .np-banner .np-title { color: #fff; font-weight:700; font-size:1.05rem; }
  .np-banner .np-artist { color: rgba(255,255,255,0.95); font-size:0.95rem }

  .now-playing .np-cover {
    width: 100%;
