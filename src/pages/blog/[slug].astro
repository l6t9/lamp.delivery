---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/article.css';
import { getCollection, type CollectionEntry } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.published);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} | lamp.delivery`} description={post.data.description} type="article" pathname="/blog">
  <main class="page article-page">
    <div class="card">
      <span class="eyebrow">published {post.data.date.toLocaleDateString('en-GB')}</span>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="muted intro">{post.data.description}</p>

      <div class="tag-row" style="margin-top:4px">
        {post.data.categories.map((category) => <span class="tag">#{category}</span>)}
      </div>

      <div class="article-content">
        <Content />
      </div>

      <a class="card-footer-link" href="/blog">back to blog <span class="material-symbols-outlined" style="font-size:16px">chevron_forward</span></a>
    </div>
  </main>
</BaseLayout>

<script>
  import '@m3e/web/icon';
</script>

<style>
  .article-page {
    display: flex;
    flex-direction: column;
    gap: var(--home-gap, 24px);
  }

  .eyebrow {
    color: var(--md-sys-color-primary);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: "Google Sans Flex", system-ui, sans-serif;
    font-weight: 500;
  }

  .post-title {
    font-family: "Google Sans Flex", system-ui, sans-serif;
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0;
  }

  .intro {
    max-width: 60ch;
  }

  .article-content {
    max-width: 74ch;
  }
</style>
